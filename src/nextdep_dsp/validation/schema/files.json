{
  "$schemas": "http://json-schema.org/draft/2020-12/schema",
  "$id": "files.json",
  "title": "filecheck",
  "description": "schema for validation of input files for pdb deposition",
  "type": "object",
  "properties": {
    "method": {
      "enum": [
        "xray",
        "fiber",
        "neutron",
        "em",
        "ec",
        "nmr",
        "ssnmr"
      ]
    },
    "subtype": {
      "enum": [
        "single",
        "helical",
        "tomography",
        "subtomogram"
      ]
    },
    "files": {
      "type": "array",
      "contains": {
        "enum": [
          "co-pdb",
          "co-cif",
          "vo-map"
        ]
      },
      "minContains": 1,
      "maxContains": 2,
      "items": {
        "enum": [
          "co-pdb",
          "co-cif",
          "xs-cif",
          "xs-mtz",
          "xa-par",
          "xa-top",
          "xa-mat",
          "layer-lines",
          "vo-map",
          "img-emdb",
          "add-map",
          "mask-map",
          "half-map",
          "fsc-xml",
          "nm-shi",
          "nm-res-amb",
          "nm-aux-amb",
          "nm-res-bio",
          "nm-res-cha",
          "nm-res-cns",
          "nm-res-cya",
          "nm-res-dyn",
          "nm-res-dyn",
          "nm-res-dyn",
          "nm-res-gro",
          "nm-aux-gro",
          "nm-res-isd",
          "nm-res-ros",
          "nm-res-syb",
          "nm-res-xpl",
          "nm-res-oth",
          "nm-pea-any",
          "nm-uni-nef",
          "nm-uni-str"
        ]
      }
    }
  },
  "required": [
    "method",
    "files"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "method": {
            "not": {
              "const": "em"
            }
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "enum": [
                "co-pdb",
                "co-cif"
              ]
            },
            "minContains": 1,
            "maxContains": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "enum": [
              "xray",
              "neutron"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "enum": [
                "xs-cif",
                "xs-mtz"
              ]
            },
            "minContains": 1,
            "maxContains": 1,
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "em"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "const": "vo-map"
            },
            "minContains": 1,
            "maxContains": 1,
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "vo-map",
                "img-emdb",
                "add-map",
                "mask-map",
                "half-map",
                "fsc-xml"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "enum": [
              "nmr",
              "ssnmr"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "nm-shi",
                "nm-res-amb",
                "nm-aux-amb",
                "nm-res-bio",
                "nm-res-cha",
                "nm-res-cns",
                "nm-res-cya",
                "nm-res-dyn",
                "nm-res-dyn",
                "nm-res-dyn",
                "nm-res-gro",
                "nm-aux-gro",
                "nm-res-isd",
                "nm-res-ros",
                "nm-res-syb",
                "nm-res-xpl",
                "nm-res-oth",
                "nm-pea-any",
                "nm-uni-nef",
                "nm-uni-str"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ec"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "enum": [
                "vo-map",
                "xs-cif",
                "xs-mtz"
              ]
            },
            "minContains": 1,
            "maxContains": 2,
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat",
                "vo-map",
                "img-emdb",
                "add-map",
                "mask-map",
                "half-map",
                "fsc-xml"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "fiber"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "const": "layer-lines"
            },
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "layer-lines",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "em"
          }
        }
      },
      "then": {
        "required": [
          "subtype"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "subtype": {
            "enum": [
              "single",
              "helical",
              "subtomogram"
            ]
          }
        },
        "required": [
          "subtype"
        ]
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "const": "half-map"
            },
            "minContains": 2,
            "maxContains": 2
          }
        }
      }
    }
  ]
}
